# ─── LLM (Ollama - Local) ─────────────────────────────────────────────────────
# Ollama runs locally, no API key needed
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1

# Recommended for 8GB RAM, CPU-only:
#   phi3:mini          → best quality (~4GB RAM, slow but great reasoning)
#   qwen2.5:1.5b       → fastest (~1.5GB RAM, good for quick responses)
#   gemma2:2b          → balanced (~2.5GB RAM, good Q&A quality)
LLM_MODEL=phi3:mini

# ─── App Settings ────────────────────────────────────────────────────────────
RESUME_UPLOAD_DIR=./data/resumes
CHROMA_DB_PATH=./data/chroma_db
FRONTEND_URL=http://localhost:5173

# ─── Database (optional for MVP - in-memory sessions used by default) ────────
# DATABASE_URL=postgresql://user:password@localhost:5432/interview_db
